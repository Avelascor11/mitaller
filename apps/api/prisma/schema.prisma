generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  WORKSHOP_MANAGER
  PRODUCTION
  PICKING
  SHIPPING
  PURCHASING
}

enum OperationalStatus {
  NEW
  WAITING_STOCK
  WAITING_PRODUCTION
  IN_PRODUCTION
  PRODUCED
  WAITING_PICKING
  PICKED
  READY_FOR_LABEL
  LABEL_CREATED
  SHIPPED
  BLOCKED
  CANCELLED
}

enum ProductionTaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  BLOCKED
  CANCELLED
}

enum PriorityLevel {
  CRITICAL
  HIGH
  NORMAL
  LOW
  BLOCKED
}

enum OrderItemStatus {
  PENDING
  RESERVED
  IN_PRODUCTION
  PRODUCED
  PICKED
  BLOCKED
  CANCELLED
}

enum StockItemType {
  BLANK_GARMENT
  TRANSFER
  PACKAGING
  FINISHED_GOOD
  MERCH
  OTHER
}

enum StockLocationType {
  WORKSHOP
  SHELF
  PRODUCED
  PACKING
  INCIDENTS
  INBOUND
}

enum PurchaseNeedStatus {
  OPEN
  ORDERED
  RECEIVED
  CANCELLED
}

enum ShipmentStatus {
  PENDING
  PARCEL_CREATED
  LABEL_CREATED
  PRINTED
  IN_TRANSIT
  DELIVERED
  CANCELLED
  ERROR
}

enum ReturnStatus {
  REQUESTED
  LABEL_CREATED
  RECEIVED
  APPROVED
  REJECTED
  CANCELLED
}

enum ReturnReason {
  WRONG_SIZE
  DEFECTIVE
  NOT_AS_DESCRIBED
  CHANGED_MIND
  WRONG_ITEM
  OTHER
}

enum ReturnType {
  RETURN
  EXCHANGE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ExceptionType {
  EXTEND_WINDOW
  FREE_LABEL
  ACCEPT_EXPIRED
  BLOCK
}

enum StockReceiptStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum BankConnectionStatus {
  PENDING
  LINKED
  EXPIRED
  ERROR
}

enum BankTransactionCategory {
  SHOPIFY_PAYOUT
  SENDCLOUD
  GARMENT_SUPPLIER
  DTF_SUPPLIER
  TAX
  ADS
  SOFTWARE
  OTHER_INCOME
  OTHER_EXPENSE
}

model User {
  id              String           @id @default(cuid())
  name            String
  email           String           @unique
  passwordHash    String
  role            Role             @default(PRODUCTION)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  assignedTasks   ProductionTask[]
  stockMovements  StockMovement[]
  activityLogs    ActivityLog[]
}

model MetaRecommendationAction {
  id               String   @id
  recommendationId String?  @map("recommendation_id")
  targetType       String   @map("target_type")
  targetId         String   @map("target_id")
  severity         String
  action           String
  message          String
  beforeJson       Json?    @map("before_json")
  afterJson        Json?    @map("after_json")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([targetId, severity, createdAt])
  @@map("meta_recommendation_actions")
}

model Order {
  id                  String             @id @default(cuid())
  shopifyOrderId      String             @unique
  orderNumber         String             @unique
  customerName        String
  customerEmail       String?
  shippingMethod      String
  shippingCountry     String?
  shippingAddressJson Json?
  financialStatus     String
  fulfillmentStatus   String?
  operationalStatus   OperationalStatus  @default(NEW)
  priorityLevel       PriorityLevel      @default(NORMAL)
  orderedAt           DateTime
  internalDeadlineAt  DateTime?
  subtotalPrice       Float?
  totalShipping       Float?
  totalTax            Float?
  totalDiscount       Float?
  totalPrice          Float?
  currency            String?
  packagePhoto        Bytes?
  packagePhotoAt      DateTime?
  preparedAt          DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  items               OrderItem[]
  productionTasks     ProductionTask[]
  stockMovements      StockMovement[]
  shipments           Shipment[]
  returns             Return[]
}

model OrderItem {
  id                 String           @id @default(cuid())
  orderId            String
  shopifyLineItemId  String?
  shopifyProductId   String?
  shopifyVariantId   String?
  sku                String
  title              String
  variantTitle       String?
  quantity           Int
  imageUrl           String?
  imageUrlsJson      Json?
  color              String?
  size               String?
  productType        String?
  unitPrice          Float?
  lineDiscount       Float?
  status             OrderItemStatus  @default(PENDING)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  order              Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productionTasks    ProductionTask[]
  returnItems        ReturnItem[]
}

model ProductionTask {
  id                  String                @id @default(cuid())
  orderId             String
  orderItemId         String?
  title               String
  sku                 String?
  productName         String
  color               String?
  size                String?
  quantity            Int
  status              ProductionTaskStatus  @default(PENDING)
  priorityLevel       PriorityLevel         @default(NORMAL)
  internalDeadlineAt  DateTime?
  blockedReason       String?
  assignedToUserId    String?
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  order               Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem           OrderItem?            @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  assignedToUser      User?                 @relation(fields: [assignedToUserId], references: [id], onDelete: SetNull)
  stockMovements      StockMovement[]
}

model StockItem {
  id                 String             @id @default(cuid())
  sku                String             @unique
  name               String
  type               StockItemType
  color              String?
  size               String?
  barcode            String?
  supplierSku        String?
  minStock           Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  levels             StockLevel[]
  movements          StockMovement[]
  receiptLines       StockReceiptLine[]
  recipeComponents   RecipeComponent[]
  purchaseNeeds      PurchaseNeed[]
  supplierOrderLines SupplierPurchaseOrderLine[]
}

model StockLocation {
  id             String          @id @default(cuid())
  code           String          @unique
  name           String
  type           StockLocationType
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  levels         StockLevel[]
  movementsFrom  StockMovement[] @relation("fromLocation")
  movementsTo    StockMovement[] @relation("toLocation")
}

model StockLevel {
  id           String        @id @default(cuid())
  stockItemId  String
  locationId   String
  quantity     Int           @default(0)
  updatedAt    DateTime      @updatedAt
  stockItem    StockItem     @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  location     StockLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([stockItemId, locationId])
}

model StockMovement {
  id              String         @id @default(cuid())
  stockItemId     String
  fromLocationId  String?
  toLocationId    String?
  quantity        Int
  reason          String
  relatedOrderId  String?
  relatedTaskId   String?
  userId          String?
  createdAt       DateTime       @default(now())
  stockItem       StockItem      @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  fromLocation    StockLocation? @relation("fromLocation", fields: [fromLocationId], references: [id], onDelete: SetNull)
  toLocation      StockLocation? @relation("toLocation", fields: [toLocationId], references: [id], onDelete: SetNull)
  relatedOrder    Order?         @relation(fields: [relatedOrderId], references: [id], onDelete: SetNull)
  relatedTask     ProductionTask? @relation(fields: [relatedTaskId], references: [id], onDelete: SetNull)
  user            User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model StockReceipt {
  id             String              @id @default(cuid())
  supplier       String?
  source         String              @default("ALBARAN_OCR")
  rawText        String?
  photo          Bytes?
  photoMimeType  String?
  status         StockReceiptStatus  @default(DRAFT)
  confirmedAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  lines          StockReceiptLine[]
}

model StockReceiptLine {
  id               String        @id @default(cuid())
  receiptId        String
  stockItemId      String?
  detectedName     String
  matchedName      String?
  sku              String?
  supplierSku      String?
  quantity         Int
  confidence       Float         @default(0)
  rawLine          String?
  createdAt        DateTime      @default(now())
  receipt          StockReceipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  stockItem        StockItem?    @relation(fields: [stockItemId], references: [id], onDelete: SetNull)
}

model Recipe {
  id                String             @id @default(cuid())
  shopifyProductId  String?
  shopifyVariantId  String?
  name              String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  components        RecipeComponent[]
}

model RecipeComponent {
  id           String     @id @default(cuid())
  recipeId     String
  stockItemId  String
  quantity     Int
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  stockItem    StockItem  @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
}

model ProductSubproductMapping {
  id             String    @id @default(cuid())
  productName    String    @unique
  productType    String?
  color          String?
  size           String?
  sku            String
  subproductName String
  imageRef       String?
  source         String    @default("MEJOR PRODUCCION")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model SupplierArticle {
  id             String   @id @default(cuid())
  supplier       String
  supplierSku    String
  styleCode      String?
  brand          String?
  productName    String
  color          String?
  size           String?
  ean            String?
  purchasePrice  Decimal? @db.Decimal(10, 2)
  weightGrams    Int?
  packQuantity   Int?
  cartonQuantity Int?
  rawDataJson    Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([supplier, supplierSku])
}

model SupplierStock {
  id                          String   @id @default(cuid())
  supplier                    String
  supplierSku                 String
  availableQuantity           Int
  stockSpain24h               Int      @default(0)
  stockCentral3To5Days        Int      @default(0)
  stockSupplier5To20Days      Int      @default(0)
  lastSyncedAt                DateTime @default(now())

  @@unique([supplier, supplierSku])
}

model PurchaseNeed {
  id                           String             @id @default(cuid())
  stockItemId                  String
  supplierSku                  String?
  neededForPendingOrders       Int
  minStockTarget               Int
  currentInternalStock         Int
  alreadyOrderedQuantity       Int                @default(0)
  recommendedPurchaseQuantity  Int
  supplierAvailableQuantity    Int?
  status                       PurchaseNeedStatus @default(OPEN)
  generatedAt                  DateTime           @default(now())
  stockItem                    StockItem          @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
}

model SupplierPurchaseOrder {
  id              String                      @id @default(cuid())
  supplier        String
  orderNumber     String                      @unique
  externalOrderId String?
  status          String                      @default("DRAFT")
  mode            String                      @default("draft")
  orderDate       DateTime
  submittedAt     DateTime?
  errorMessage    String?
  rawRequestJson  Json?
  rawResponseJson Json?
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  lines           SupplierPurchaseOrderLine[]

  @@unique([supplier, orderDate])
  @@index([supplier, status])
}

model SupplierPurchaseOrderLine {
  id                             String                @id @default(cuid())
  orderId                        String
  stockItemId                    String
  supplierSku                    String
  name                           String
  color                          String?
  size                           String?
  quantity                       Int
  supplierAvailableQuantity      Int?
  supplierStockSpain24h          Int?
  supplierStockCentral3To5Days   Int?
  supplierStockSupplier5To20Days Int?
  purchasePrice                  Decimal?              @db.Decimal(10, 2)
  rawDataJson                    Json?
  createdAt                      DateTime              @default(now())
  order                          SupplierPurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stockItem                      StockItem             @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@index([supplierSku])
}

model Shipment {
  id                 String         @id @default(cuid())
  orderId            String
  provider           String
  sendcloudParcelId  String?
  trackingNumber     String?
  trackingUrl        String?
  carrier            String?
  labelUrl           String?
  cost               Float?
  costCurrency       String?
  packagePhoto       Bytes?
  packagePhotoAt     DateTime?
  trackingStatus     String?
  trackingSyncedAt   DateTime?
  status             ShipmentStatus @default(PENDING)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  order              Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model BankConnection {
  id              String                @id @default(cuid())
  provider        String                @default("GOCARDLESS")
  institutionId   String
  institutionName String?
  requisitionId   String                @unique
  reference       String                @unique
  link            String?
  status          BankConnectionStatus  @default(PENDING)
  agreementId     String?
  accountsJson    Json?
  rawDataJson     Json?
  connectedAt     DateTime?
  expiresAt       DateTime?
  lastSyncedAt    DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  accounts        BankAccount[]
}

model BankAccount {
  id                String             @id @default(cuid())
  connectionId      String
  providerAccountId String             @unique
  iban              String?
  name              String?
  currency          String?
  ownerName         String?
  product           String?
  cashAccountType   String?
  rawDataJson       Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  connection        BankConnection     @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  transactions      BankTransaction[]
}

model BankTransaction {
  id                    String                   @id @default(cuid())
  accountId             String
  providerTransactionId String?
  bookingDate           DateTime
  valueDate             DateTime?
  amount                Float
  currency              String                   @default("EUR")
  description           String
  merchantName          String?
  remittanceInfo        String?
  counterpartyName      String?
  counterpartyIban      String?
  category              BankTransactionCategory  @default(OTHER_EXPENSE)
  orderNumber           String?
  rawDataJson           Json?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  account               BankAccount              @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, providerTransactionId])
  @@index([bookingDate])
  @@index([category])
}

model PayoutMark {
  id        String   @id @default(cuid())
  payoutId  String   @unique
  markedAt  DateTime @default(now())
}

model ShippingRule {
  id                            String   @id @default(cuid())
  name                          String
  shopifyShippingMethodContains String
  maxHoursToProduce             Int
  priorityBoost                 Int      @default(0)
  sendcloudMethodCode           String?
  shouldCreateLabel             Boolean  @default(true)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
}

model ActivityLog {
  id           String   @id @default(cuid())
  entityType   String
  entityId     String
  action       String
  message      String
  userId       String?
  metadataJson Json?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Return {
  id                   String        @id @default(cuid())
  orderId              String
  shopifyOrderNumber   String
  customerEmail        String
  customerName         String
  type                 ReturnType    @default(RETURN)
  status               ReturnStatus  @default(REQUESTED)
  paymentStatus        PaymentStatus @default(PENDING)
  notes                String?
  sendcloudReturnId    String?
  labelUrl             String?
  trackingNumber       String?
  carrier              String?
  deliveredAt          DateTime?
  shopifyDraftOrderId  String?
  exchangeOrderName    String?
  exchangeOrderUrl     String?
  checkoutUrl          String?
  refundAmount         Float?
  chargeAmount         Float?
  labelFee             Float?
  totalAmount          Float?
  paidAt               DateTime?
  receivedAt           DateTime?
  verifiedAt           DateTime?
  verificationNotes    String?
  verificationStatus   String?
  refundedAt           DateTime?
  refundId             String?
  shopifyRefundAmount  Float?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  order                Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items                ReturnItem[]
  photos               ReturnPhoto[]
}

model ReturnPhoto {
  id        String   @id @default(cuid())
  returnId  String
  data      String   @db.Text
  createdAt DateTime @default(now())
  return    Return   @relation(fields: [returnId], references: [id], onDelete: Cascade)
}

model ReturnConfig {
  id                    String   @id @default("singleton")
  windowDays            Int      @default(15)
  labelPrice            Float    @default(4.95)
  shippingProductCode   String?
  exchangePolicy        String   @default("ANY")
  termsText             String?
  enabled               Boolean  @default(true)
  updatedAt             DateTime @updatedAt
}

model ReturnException {
  id            String        @id @default(cuid())
  orderNumber   String?
  customerEmail String?
  type          ExceptionType
  extraDays     Int?
  notes         String?
  expiresAt     DateTime?
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([orderNumber])
  @@index([customerEmail])
}

model ReturnItem {
  id                    String       @id @default(cuid())
  returnId              String
  orderItemId           String
  quantity              Int
  reason                ReturnReason
  notes                 String?
  replacementVariantId  String?
  replacementProductId  String?
  replacementTitle      String?
  replacementImageUrl   String?
  replacementPrice      Float?
  createdAt             DateTime     @default(now())
  return                Return       @relation(fields: [returnId], references: [id], onDelete: Cascade)
  orderItem             OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
}

enum InfluencerStage {
  PROSPECT
  CONTACTED
  NEGOTIATING
  VIDEO_RECEIVED
  PUBLISHED
  REJECTED
}

enum UgcStatus {
  PENDING
  APPROVED
  REJECTED
  PUBLISHED
}

enum CollabStatus {
  OPEN
  NEGOTIATING
  PRODUCT_SENT
  AWAITING_CONTENT
  CONTENT_RECEIVED
  PUBLISHED
  CLOSED
  CANCELLED
}

enum CollabType {
  GIFT
  PAID
  AFFILIATE
}

model Influencer {
  id            String          @id @default(cuid())
  igHandle      String          @unique
  fullName      String?
  manychatId    String?         @unique
  followers     Int?
  email         String?
  stage         InfluencerStage @default(PROSPECT)
  tags          String[]
  notes         String?
  lastMessage   String?
  lastMessageAt DateTime?
  source        String?
  detectionScore Int           @default(0)
  detectionReason String?
  suggestedAction String?
  firstDetectedAt DateTime?
  lastInboundAt DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  submissions   UgcSubmission[]
  collaborations Collaboration[]

  @@index([stage])
  @@index([detectionScore])
}

model Collaboration {
  id             String          @id @default(cuid())
  influencerId   String
  title          String
  status         CollabStatus    @default(OPEN)
  type           CollabType      @default(GIFT)
  compensation   Float?
  productSent    String?
  deliverables   String?
  discountCode   String?
  metaCampaignId String?
  deadline       DateTime?
  openedAt       DateTime        @default(now())
  closedAt       DateTime?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  influencer     Influencer      @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  submissions    UgcSubmission[]

  @@index([influencerId])
  @@index([status])
}

model UgcSubmission {
  id              String         @id @default(cuid())
  influencerId    String
  collaborationId String?
  videoUrl        String?
  thumbnailUrl    String?
  caption         String?
  type            String         @default("UGC")
  status          UgcStatus      @default(PENDING)
  metaCampaignId  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  influencer      Influencer     @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  collaboration   Collaboration? @relation(fields: [collaborationId], references: [id], onDelete: SetNull)

  @@index([influencerId])
  @@index([status])
}

model PortalConfig {
  id             String   @id @default("singleton")
  logoUrl        String?
  faviconUrl     String?
  backgroundUrl  String?
  primaryColor   String   @default("#007AFF")
  cardStyle      String   @default("light")
  titleText      String   @default("Cambios & Devoluciones")
  subtitleText   String   @default("Gestiona tu devolución de forma rápida")
  policyUrl      String?
  updatedAt      DateTime @updatedAt
}
